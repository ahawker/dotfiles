[alias]
	pr = "!hub pull-request"
[apply]
	whitespace = fix
[color]
	ui = auto
[commit]
	gpgsign = false
[core]
	attributesfile = ~/.gitattributes
	excludesfile = ~/.gitignore
	trustctime = false
	whitespace = space-before-tab,-indent-with-non-tab,trailing-space
[diff]
	renames = copies
[help]
	autocorrect = 1
[push]
	default = simple
[user]
	name = Andrew Hawker
	email = andrew.hawker@auth0.com
[fetch]
	prune = true
[pull]
	rebase = true
[init]
	defaultBranch = main
